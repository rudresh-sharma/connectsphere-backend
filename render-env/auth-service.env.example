PORT=8080
SERVER_PORT=8080

EUREKA_ENABLED=true
EUREKA_DEFAULT_ZONE=https://your-eureka-service.onrender.com/eureka/

AUTH_DB_URL=jdbc:mysql://your-mysql-host:3306/connectsphere_auth?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
AUTH_DB_USERNAME=your_db_username
AUTH_DB_PASSWORD=your_db_password

REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

RABBITMQ_HOST=your-rabbitmq-host
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=your_rabbitmq_username
RABBITMQ_PASSWORD=your_rabbitmq_password

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRATION_SECONDS=86400
APP_ADMIN_USERNAME=admin
APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_PASSWORD=replace-with-admin-password
APP_ADMIN_FULL_NAME=System Admin

OAUTH_SUCCESS_URL=https://your-frontend-service.onrender.com/auth/callback
OAUTH_FAILURE_URL=https://your-frontend-service.onrender.com/login
OAUTH_SETUP_URL=https://your-frontend-service.onrender.com/auth/choose-username

POST_SERVICE_URL=https://your-post-service.onrender.com
SEARCH_SERVICE_URL=https://your-search-service.onrender.com
FOLLOW_SERVICE_URL=https://your-follow-service.onrender.com
NOTIFICATION_SERVICE_URL=https://your-notification-service.onrender.com

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_PROFILE_FOLDER=connectsphere/profiles
