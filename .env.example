# ==========================================
# Core Infrastructure
# ==========================================
EUREKA_ENABLED=true
EUREKA_DEFAULT_ZONE=http://localhost:8761/eureka/
EUREKA_HOSTNAME=localhost
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=connectsphere
RABBITMQ_PASSWORD=change-me
ELASTICSEARCH_URIS=http://localhost:9200

# ==========================================
# Frontend and Gateway
# ==========================================
FRONTEND_URL=http://localhost:4200
GATEWAY_ALLOWED_ORIGIN=http://localhost:4200
FOLLOW_CORS_ALLOWED_ORIGIN=http://localhost:4200
OAUTH_SUCCESS_URL=http://localhost:4200/auth/callback
OAUTH_FAILURE_URL=http://localhost:4200/login
OAUTH_SETUP_URL=http://localhost:4200/auth/choose-username

# ==========================================
# Service URLs
# ==========================================
AUTH_SERVICE_URL=http://localhost:8080
POST_SERVICE_URL=http://localhost:8081
FOLLOW_SERVICE_URL=http://localhost:8082
COMMENT_SERVICE_URL=http://localhost:8083
LIKE_SERVICE_URL=http://localhost:8084
NOTIFICATION_SERVICE_URL=http://localhost:8085
MEDIA_SERVICE_URL=http://localhost:8086
SEARCH_SERVICE_URL=http://localhost:8087
PAYMENT_GATEWAY_URL=http://localhost:8089

# ==========================================
# Database Connections
# ==========================================
AUTH_DB_URL=jdbc:mysql://localhost:3307/connectsphere_auth?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
AUTH_DB_USERNAME=root
AUTH_DB_PASSWORD=change-me
POST_DB_URL=jdbc:mysql://localhost:3308/connectsphere_post?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
POST_DB_USERNAME=root
POST_DB_PASSWORD=change-me
FOLLOW_DB_URL=jdbc:mysql://localhost:3309/connectsphere_follow?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
FOLLOW_DB_USERNAME=root
FOLLOW_DB_PASSWORD=change-me
COMMENT_DB_URL=jdbc:mysql://localhost:3310/connectsphere_comment?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&useUnicode=true&characterEncoding=UTF-8&connectionCollation=utf8mb4_unicode_ci
COMMENT_DB_USERNAME=root
COMMENT_DB_PASSWORD=change-me
LIKE_DB_URL=jdbc:mysql://localhost:3311/connectsphere_like?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
LIKE_DB_USERNAME=root
LIKE_DB_PASSWORD=change-me
NOTIFICATION_DB_URL=jdbc:mysql://localhost:3312/connectsphere_notification?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
NOTIFICATION_DB_USERNAME=root
NOTIFICATION_DB_PASSWORD=change-me
MEDIA_DB_URL=jdbc:mysql://localhost:3313/connectsphere_media?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
MEDIA_DB_USERNAME=root
MEDIA_DB_PASSWORD=change-me
SEARCH_DB_URL=jdbc:mysql://localhost:3314/connectsphere_search?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SEARCH_DB_USERNAME=root
SEARCH_DB_PASSWORD=change-me

# ==========================================
# Auth Service Security
# ==========================================
JWT_SECRET=replace-with-a-long-base64-secret
JWT_EXPIRATION_SECONDS=86400
APP_ADMIN_USERNAME=admin
APP_ADMIN_EMAIL=admin@connectsphere.local
APP_ADMIN_PASSWORD=change-me
APP_ADMIN_FULL_NAME=System Admin
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ==========================================
# Cloudinary
# ==========================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=connectsphere/posts
CLOUDINARY_PROFILE_FOLDER=connectsphere/profiles
CLOUDINARY_MAX_VIDEO_DURATION_SECONDS=120

# ==========================================
# Email and Notifications
# ==========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@connectsphere.local

# ==========================================
# Payments
# ==========================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PROMOTE_POST_AMOUNT_PAISE=9900
RAZORPAY_PROMOTE_POST_DURATION_DAYS=7

# ==========================================
# Docker and Local Ports
# ==========================================
AUTH_DB_PORT=3307
POST_DB_PORT=3308
FOLLOW_DB_PORT=3309
COMMENT_DB_PORT=3310
LIKE_DB_PORT=3311
NOTIFICATION_DB_PORT=3312
MEDIA_DB_PORT=3313
SEARCH_DB_PORT=3314
ES_PORT=9200
RABBITMQ_MANAGEMENT_PORT=15672
SONARQUBE_PORT=9000
